\mode<presentation>

% ---- Font loading strategy ----
% 1. luatex85 provides compat shims for mtpro2 under LuaTeX
% 2. mtpro2 sets up math fonts via NFSS (Type1)
% 3. fontspec[no-math] sets up text fonts (OTF) without touching math

\RequirePackage{luatex85}
\RequirePackage[lite]{mtpro2}
\RequirePackage[no-math]{fontspec}

% --- Sans serif: Whitney (primary text font in Beamer) ---
\setsansfont{Whitney}[
  Path           = /home/tobias/texmf/fonts/opentype/whitney/,
  Extension      = .otf,
  UprightFont    = Whitney-Book,
  BoldFont       = Whitney-Semibold,
  ItalicFont     = Whitney-BookItalic,
  BoldItalicFont = Whitney-SemiboldItalic,
]

% --- Monospace: Iosevka ---
\setmonofont{Iosevka}[
  Scale          = MatchLowercase,
]

% --- Serif: TeX Gyre Termes (Times-compatible fallback) ---
\setmainfont{TeX Gyre Termes}

% --- Beamer font assignments ---
\setbeamerfont{title}{size=\LARGE, series=\bfseries}
\setbeamerfont{subtitle}{size=\large}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{frametitle}{size=\Large, series=\bfseries}
\setbeamerfont{framesubtitle}{size=\normalsize}
\setbeamerfont{normal text}{size=\large}
\setbeamerfont{section divider}{size=\LARGE, series=\bfseries}
\setbeamerfont{footline}{size=\tiny}

\mode<all>
