\mode<presentation>

% --- Whitney Teal palette ---
\definecolor{tjo@black}{HTML}{000000}
\definecolor{tjo@white}{HTML}{FFFFFF}
\definecolor{tjo@darkteal}{HTML}{335B74}
\definecolor{tjo@lightgrey}{HTML}{DFE3E5}
\definecolor{tjo@cyan}{HTML}{1CADE4}
\definecolor{tjo@medblue}{HTML}{2683C6}
\definecolor{tjo@brightcyan}{HTML}{27CED7}
\definecolor{tjo@green}{HTML}{42BA97}
\definecolor{tjo@darkgreen}{HTML}{3E8853}
\definecolor{tjo@teal}{HTML}{62A39F}

% --- Code block colors ---
\definecolor{tjo@codebg}{HTML}{F0F2F3}
\definecolor{tjo@codeborder}{HTML}{1CADE4}

% --- Beamer color roles ---
\setbeamercolor{normal text}{fg=tjo@black, bg=tjo@white}
\setbeamercolor{structure}{fg=tjo@darkteal}

\setbeamercolor{title}{fg=tjo@darkteal}
\setbeamercolor{subtitle}{fg=tjo@black!80}
\setbeamercolor{author}{fg=tjo@black!60}
\setbeamercolor{date}{fg=tjo@black!50}
\setbeamercolor{institute}{fg=tjo@black!60}

\setbeamercolor{frametitle}{fg=tjo@darkteal, bg=}
\setbeamercolor{framesubtitle}{fg=tjo@black!60}

\setbeamercolor{section divider}{fg=tjo@white, bg=tjo@darkteal}

\setbeamercolor{footline}{fg=tjo@black!40, bg=}

\setbeamercolor{block title}{fg=tjo@white, bg=tjo@cyan}
\setbeamercolor{block body}{fg=tjo@black, bg=tjo@lightgrey}

\setbeamercolor{alerted text}{fg=tjo@cyan}

\setbeamercolor{item}{fg=tjo@cyan}

\mode<all>
